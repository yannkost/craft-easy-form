{
  "easyForm": { "type": "form", "version": 1 },
  "form": {
    "name": "E2E Notify Attachments",
    "handle": "e2eAttach",
    "description": "Notification attaches the uploaded file, with a size guard (e2e).",
    "fieldLayout": {
      "schemaVersion": 3,
      "extraFieldPolicy": "allowListed",
      "pages": [
        {
          "id": "page_1",
          "label": "Page 1",
          "rows": [
            {
              "id": "row_1",
              "stackOnMobile": true,
              "fields": [
                { "id": "f1", "type": "text", "label": "Name", "handle": "name", "required": true },
                { "id": "f2", "type": "email", "label": "Email", "handle": "email", "required": true },
                { "id": "f3", "type": "file", "label": "Document", "handle": "document", "maxFileSize": 5, "allowedFileTypes": "txt" }
              ]
            }
          ]
        }
      ],
      "frontendFields": [],
      "promotedFields": { "primaryEmail": "email", "primaryName": "name" }
    },
    "enabled": true,
    "captchaProvider": null,
    "notificationSettings": [
      {
        "enabled": true,
        "name": "Admin with attachment",
        "recipients": ["attach@example.test"],
        "subject": "Submission with attachment",
        "senderEmail": "no-reply@example.test",
        "senderName": "Easy Form",
        "attachFiles": true
      }
    ]
  }
}
