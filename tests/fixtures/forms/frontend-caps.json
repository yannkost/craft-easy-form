{
  "easyForm": { "type": "form", "version": 1 },
  "form": {
    "name": "E2E Frontend Caps",
    "handle": "e2eFrontendCaps",
    "description": "Allow-listed frontend fields with maxItems / maxLength caps (e2e).",
    "fieldLayout": {
      "schemaVersion": 3,
      "extraFieldPolicy": "allowListed",
      "pages": [
        {
          "id": "page_1",
          "label": "Page 1",
          "rows": [
            {
              "id": "row_1",
              "stackOnMobile": true,
              "fields": [
                { "id": "f1", "type": "text", "label": "Name", "handle": "name", "required": true },
                { "id": "f2", "type": "email", "label": "Email", "handle": "email", "required": true }
              ]
            }
          ]
        }
      ],
      "frontendFields": [
        { "handle": "tags", "label": "Tags", "type": "array", "multiple": true, "maxItems": 2 },
        { "handle": "bio", "label": "Bio", "type": "string", "maxLength": 5 }
      ],
      "promotedFields": { "primaryEmail": "email", "primaryName": "name" }
    },
    "enabled": true,
    "captchaProvider": null
  }
}
