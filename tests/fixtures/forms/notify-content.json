{
  "easyForm": { "type": "form", "version": 1 },
  "form": {
    "name": "E2E Notify Content",
    "handle": "e2eNotifyContent",
    "description": "Custom-content notification: newlines survive, |b bolds a token (e2e).",
    "fieldLayout": {
      "schemaVersion": 3,
      "extraFieldPolicy": "allowListed",
      "pages": [
        {
          "id": "page_1",
          "label": "Page 1",
          "rows": [
            {
              "id": "row_1",
              "stackOnMobile": true,
              "fields": [
                { "id": "f1", "type": "text", "label": "Name", "handle": "name", "required": true },
                { "id": "f2", "type": "email", "label": "Email", "handle": "email", "required": true }
              ]
            }
          ]
        }
      ],
      "frontendFields": [],
      "promotedFields": { "primaryEmail": "email", "primaryName": "name" }
    },
    "enabled": true,
    "captchaProvider": null,
    "notificationSettings": [
      {
        "enabled": true,
        "name": "Custom content",
        "recipients": ["notify-content@example.test"],
        "subject": "Custom content notify",
        "senderEmail": "no-reply@example.test",
        "senderName": "Easy Form",
        "siteContent": {
          "default": "First line\nSecond line {label[name]|b}: {field[name]}"
        }
      }
    ]
  }
}
