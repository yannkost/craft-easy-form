{
  "easyForm": { "type": "form", "version": 1 },
  "form": {
    "name": "E2E Notify CC/BCC",
    "handle": "e2eNotifyCc",
    "description": "Form whose notification copies a CC and BCC recipient (e2e).",
    "fieldLayout": {
      "schemaVersion": 3,
      "extraFieldPolicy": "allowListed",
      "pages": [
        {
          "id": "page_1",
          "label": "Page 1",
          "rows": [
            {
              "id": "row_1",
              "stackOnMobile": true,
              "fields": [
                { "id": "f1", "type": "text", "label": "Name", "handle": "name", "required": true },
                { "id": "f2", "type": "email", "label": "Email", "handle": "email", "required": true }
              ]
            }
          ]
        }
      ],
      "frontendFields": [],
      "promotedFields": { "primaryEmail": "email", "primaryName": "name" }
    },
    "enabled": true,
    "captchaProvider": null,
    "notificationSettings": [
      {
        "enabled": true,
        "name": "Admin notification (CC/BCC)",
        "recipients": ["notify-to@example.test"],
        "cc": "notify-cc@example.test",
        "bcc": "notify-bcc@example.test",
        "subject": "New CC/BCC submission",
        "senderEmail": "no-reply@example.test",
        "senderName": "Easy Form"
      }
    ]
  }
}
