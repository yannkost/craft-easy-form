{
  "easyForm": { "type": "form", "version": 1 },
  "form": {
    "name": "E2E Conditional Notify",
    "handle": "e2eCondNotify",
    "description": "Notification that only sends when topic = sales (e2e).",
    "fieldLayout": {
      "schemaVersion": 3,
      "extraFieldPolicy": "allowListed",
      "pages": [
        {
          "id": "page_1",
          "label": "Page 1",
          "rows": [
            {
              "id": "row_1",
              "stackOnMobile": true,
              "fields": [
                { "id": "f1", "type": "text", "label": "Name", "handle": "name", "required": true },
                { "id": "f2", "type": "email", "label": "Email", "handle": "email", "required": true },
                { "id": "f3", "type": "text", "label": "Topic", "handle": "topic", "required": false }
              ]
            }
          ]
        }
      ],
      "frontendFields": [],
      "promotedFields": { "primaryEmail": "email", "primaryName": "name" }
    },
    "enabled": true,
    "captchaProvider": null,
    "notificationSettings": [
      {
        "enabled": true,
        "name": "Sales only",
        "recipients": ["cond-notify@example.test"],
        "subject": "Conditional notify",
        "senderEmail": "no-reply@example.test",
        "senderName": "Easy Form",
        "conditions": {
          "action": "show",
          "logic": "all",
          "rules": [
            { "field": "topic", "operator": "equals", "value": "sales" }
          ]
        }
      }
    ]
  }
}
