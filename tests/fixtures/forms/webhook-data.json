{
  "easyForm": { "type": "form", "version": 1 },
  "form": {
    "name": "E2E Webhook (data-only)",
    "handle": "e2eWebhookData",
    "description": "Webhook form using the flat data-only payload (e2e).",
    "webhookUrl": "http://localhost/webhook-sink.php",
    "webhookPayload": "data",
    "fieldLayout": {
      "schemaVersion": 3,
      "extraFieldPolicy": "allowListed",
      "pages": [
        {
          "id": "page_1",
          "label": "Page 1",
          "rows": [
            {
              "id": "row_1",
              "stackOnMobile": true,
              "fields": [
                { "id": "f1", "type": "text", "label": "Name", "handle": "name", "required": true },
                { "id": "f2", "type": "email", "label": "Email", "handle": "email", "required": true }
              ]
            }
          ]
        }
      ],
      "frontendFields": [],
      "promotedFields": { "primaryEmail": "email", "primaryName": "name" }
    },
    "enabled": true,
    "captchaProvider": null
  }
}
