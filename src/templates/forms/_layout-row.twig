{% import '_includes/forms' as forms %}

{% set pageIndex = pageIndex|default(0) %}
{% set rowPrefix = 'pages[' ~ pageIndex ~ '][rows][' ~ rowIndex ~ ']' %}
<div class="layout-row" data-row-index="{{ rowIndex }}" data-page-index="{{ pageIndex }}">
    <div class="layout-row-header">
        <div class="layout-row-handle">
            <span class="move icon" title="{{ 'Reorder'|t('app') }}"></span>
        </div>
        <div class="layout-row-label">
            <strong>{{ 'Row'|t('easy-form') }} {{ rowIndex + 1 }}</strong>
            <span class="field-count-badge">{{ row.fields|default([])|length }} {{ 'fields'|t('easy-form') }}</span>
            <span class="ef-row-target-badge">{{ 'Fields land here'|t('easy-form') }}</span>
        </div>
        <div class="layout-row-actions">
            <button type="button" class="btn small delete-row" title="{{ 'Delete Row'|t('easy-form') }}">
                <span data-icon="trash" aria-label="{{ 'Delete Row'|t('easy-form') }}"></span>
            </button>
        </div>
    </div>
    
    <div class="layout-row-content">
        <nav class="ef-tabs">
            <a class="ef-tab active" data-tab="fields">{{ 'Fields'|t('easy-form') }}</a>
            <a class="ef-tab" data-tab="settings">{{ 'Settings'|t('easy-form') }}</a>
            <a class="ef-tab" data-tab="conditions">{{ 'Conditions'|t('easy-form') }}</a>
        </nav>
        
        <div class="row-tab-content">
            <div class="row-tab-pane active" data-pane="fields">
                <div class="layout-row-fields">
                    <input type="hidden" name="pages[{{ pageIndex }}][rows][{{ rowIndex }}][id]" value="{{ row.id ?? 'row_' ~ (pageIndex + 1) ~ '_' ~ (rowIndex + 1) }}">
                    
                    {% set fields = row.fields|default([]) %}
                    {% for field in fields %}
                        {% include 'easy-form/forms/_field-in-row' with {
                            field: field,
                            rowIndex: rowIndex,
                            fieldIndex: loop.index0,
                            pageIndex: pageIndex
                        } %}
                    {% endfor %}
                    
                    {% if fields|length == 0 %}
                        <div class="empty-row-message">
                            <p class="light">{{ 'This row is empty. Drag a field here from the sidebar.'|t('easy-form') }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
            
            <div class="row-tab-pane" data-pane="settings" style="display: none;">
                <div class="layout-row-settings">
                    {{ forms.textField({
                        label: 'Row ID'|t('easy-form'),
                        instructions: 'HTML ID attribute for this row.'|t('easy-form'),
                        name: 'pages[' ~ pageIndex ~ '][rows][' ~ rowIndex ~ '][rowId]',
                        value: row.rowId ?? '',
                        class: 'code',
                        placeholder: 'e.g., contact-row'
                    }) }}

                    {{ forms.textField({
                        label: 'CSS Classes'|t('easy-form'),
                        instructions: 'Space-separated CSS classes for this row.'|t('easy-form'),
                        name: 'pages[' ~ pageIndex ~ '][rows][' ~ rowIndex ~ '][classList]',
                        value: row.classList ?? '',
                        class: 'code',
                        placeholder: 'e.g., form-row custom-row'
                    }) }}

                    {# Per-site structural localization: turn a site off to drop this
                       row from that site's form (render, validation and storage). #}
                    {% set rowSites = craft.app.sites.allSites %}
                    {% if rowSites|length > 1 %}
                        {% set primarySite = craft.app.sites.primarySite %}
                        {% set otherRowSites = rowSites|filter(s => s.id != primarySite.id) %}
                        <div class="ef-site-enable">
                            <div class="field"><div class="heading">
                                <label>{{ 'Enabled on these sites'|t('easy-form') }}</label>
                                <div class="instructions"><p>{{ "Turn a site off to drop this row from that site's form. It's excluded from rendering, validation and the stored submission."|t('easy-form') }}</p></div>
                            </div></div>
                            {{ forms.lightswitchField({
                                label: primarySite.name ~ ' (' ~ primarySite.handle ~ ')',
                                name: rowPrefix ~ '[siteEnabled][' ~ primarySite.handle ~ ']',
                                on: (row.siteEnabled[primarySite.handle] ?? true) ? true : false,
                                onValue: '1',
                                offValue: '0'
                            }) }}
                            {% if otherRowSites|length %}
                                {% set siteWord = otherRowSites|length == 1 ? 'site'|t('easy-form') : 'sites'|t('easy-form') %}
                                <button type="button" class="ef-localized-toggle" aria-expanded="false"><span class="ef-localized-caret" aria-hidden="true"></span><span class="ef-localized-globe" aria-hidden="true"></span>{{ 'Other sites'|t('easy-form') }} <span class="ef-localized-count">{{ otherRowSites|length }} {{ siteWord }}</span></button>
                                <div class="ef-localized-others" hidden>
                                    {% for site in otherRowSites %}
                                        {{ forms.lightswitchField({
                                            label: site.name ~ ' (' ~ site.handle ~ ')',
                                            name: rowPrefix ~ '[siteEnabled][' ~ site.handle ~ ']',
                                            on: (row.siteEnabled[site.handle] ?? true) ? true : false,
                                            onValue: '1',
                                            offValue: '0'
                                        }) }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="row-tab-pane" data-pane="conditions" style="display: none;">
                <p class="light">{{ 'Show or hide this entire row based on the value of another field.'|t('easy-form') }}</p>

                {% set condRules = row.conditions.rules|default([]) %}

                <div class="ef-cond-action-logic">
                {{ forms.selectField({
                    label: 'Action'|t('easy-form'),
                    name: rowPrefix ~ '[conditions][action]',
                    value: row.conditions.action|default('show'),
                    options: [
                        {label: 'Show this row when...'|t('easy-form'), value: 'show'},
                        {label: 'Hide this row when...'|t('easy-form'), value: 'hide'}
                    ]
                }) }}
                {{ forms.selectField({
                    label: 'Logic'|t('easy-form'),
                    name: rowPrefix ~ '[conditions][logic]',
                    value: row.conditions.logic|default('all'),
                    options: [
                        {label: 'All rules match (AND)'|t('easy-form'), value: 'all'},
                        {label: 'Any rule matches (OR)'|t('easy-form'), value: 'any'}
                    ]
                }) }}
                <button type="button" class="btn add-condition-rule" data-field-prefix="{{ rowPrefix }}">{{ 'Add Rule'|t('easy-form') }}</button>
                </div>

                <div class="condition-rules" data-field-prefix="{{ rowPrefix }}">
                    {% for rule in condRules %}
                        <div class="condition-rule" data-rule-index="{{ loop.index0 }}">
                            <input type="text" name="{{ rowPrefix ~ '[conditions][rules][' ~ loop.index0 ~ '][field]' }}" value="{{ rule.field|default('') }}" placeholder="{{ 'Field handle'|t('easy-form') }}" class="text ef-cond-field" list="ef-condition-handles">
                            <select name="{{ rowPrefix ~ '[conditions][rules][' ~ loop.index0 ~ '][operator]' }}" class="text ef-cond-operator">
                                {% for op in [{v:'equals',l:'Equals'},{v:'notEquals',l:'Not Equals'},{v:'contains',l:'Contains'},{v:'notContains',l:'Not Contains'},{v:'isEmpty',l:'Is Empty'},{v:'isNotEmpty',l:'Is Not Empty'}] %}
                                    <option value="{{ op.v }}"{{ (rule.operator|default('equals')) == op.v ? ' selected' }}>{{ op.l|t('easy-form') }}</option>
                                {% endfor %}
                            </select>
                            <input type="text" name="{{ rowPrefix ~ '[conditions][rules][' ~ loop.index0 ~ '][value]' }}" value="{{ rule.value|default('') }}" placeholder="{{ 'Value'|t('easy-form') }}" class="text ef-cond-value">
                            {% if craft.app.sites.allSites|length > 1 %}
                                <select name="{{ rowPrefix ~ '[conditions][rules][' ~ loop.index0 ~ '][site]' }}" class="text ef-cond-site" title="{{ 'Applies on'|t('easy-form') }}">
                                    <option value="all"{{ (rule.site|default('all')) == 'all' ? ' selected' }}>{{ 'All sites'|t('easy-form') }}</option>
                                    {% for s in craft.app.sites.allSites %}
                                        <option value="{{ s.handle }}"{{ (rule.site|default('all')) == s.handle ? ' selected' }}>{{ s.name }}</option>
                                    {% endfor %}
                                </select>
                            {% endif %}
                            <button type="button" class="btn small remove-condition-rule" title="{{ 'Remove'|t('easy-form') }}"><span data-icon="trash"></span></button>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
