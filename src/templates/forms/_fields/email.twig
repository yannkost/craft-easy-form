<input
    type="email"
    id="{{ field.fieldId|default('') ?: formId ~ '-' ~ field.handle }}"
    name="fields[{{ field.handle }}]"
    {% if field.placeholder|default('') %}placeholder="{{ field.placeholder }}"{% endif %}
    {# A render-time value override — easyForm('x', { values: { handle: '…' } }) —
       wins over the builder default and its per-site variants. #}
    {% set fieldDefault = options.values[field.handle] ?? field.siteDefaultValues[currentSite.handle]|default(field.defaultValue|default('')) %}
    {% if fieldDefault is not same as('') %}value="{{ fieldDefault }}"{% endif %}
    {% if field.required|default(false) %}required{% endif %}
    {% if field.siteRequiredMessages[currentSite.handle] ?? null %}data-required-message="{{ field.siteRequiredMessages[currentSite.handle] }}"{% endif %}
    {% if field.siteInvalidMessages[currentSite.handle] ?? null %}data-invalid-message="{{ field.siteInvalidMessages[currentSite.handle] }}"{% endif %}
    {% if fieldHelp|default('') %}aria-describedby="{{ fieldInputId }}-help"{% endif %}
    data-field-type="email"
>
